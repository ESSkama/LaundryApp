@model List<Laundry.Models.Order>
@{
    ViewData["Title"] = "Completed Wash Cycles";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";

    int totalCycles      = ViewBag.TotalCycles      ?? 0;
    // decimal totalKg      = ViewBag.TotalKgProcessed ?? 0m;
    // decimal totalRevenue = ViewBag.TotalRevenue      ?? 0m;
    int thisWeekCount    = ViewBag.ThisWeekCount     ?? 0;
    int currentPage      = ViewBag.CurrentPage       ?? 1;
    int totalPages       = ViewBag.TotalPages        ?? 1;
    string? search       = ViewBag.Search;
    string? filterService = ViewBag.FilterService;
    string? filterTier   = ViewBag.FilterTier;

    var serviceTypes = (ViewBag.ServiceTypes as List<string>) ?? new List<string>();
    var packageTiers = (ViewBag.PackageTiers as List<string>) ?? new List<string>();
}

<div class="container-fluid px-0 py-1">

    @* ── Stats strip ─────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">

        <div class="col-6 col-lg-3">
            <div class="stat-card border border-opacity-10" style="border-color:#3D5A80!important;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value" style="color:#3D5A80;">@totalCycles</div>
                        <div class="stat-label fw-semibold text-uppercase mt-1" style="font-size:.72rem;">Total Cycles</div>
                    </div>
                    <div class="rounded-3 p-3" style="background:rgba(61,90,128,.1);">
                        <i class="fas fa-clock-rotate-left fa-2x" style="color:#3D5A80;"></i>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">All orders processed by your station</small>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="stat-card border border-opacity-10" style="border-color:#2A9D8F!important;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value" style="color:#2A9D8F;">@thisWeekCount</div>
                        <div class="stat-label fw-semibold text-uppercase mt-1" style="font-size:.72rem;">This Week</div>
                    </div>
                    <div class="rounded-3 p-3" style="background:rgba(42,157,143,.1);">
                        <i class="fas fa-calendar-week fa-2x" style="color:#2A9D8F;"></i>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">Cycles completed in last 7 days</small>
            </div>
        </div>

        @* <div class="col-6 col-lg-3">
            <div class="stat-card border border-warning border-opacity-20">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value text-warning">@totalKg.ToString("F1") <span style="font-size:1.1rem;">kg</span></div>
                        <div class="stat-label fw-semibold text-uppercase mt-1" style="font-size:.72rem;">Total Fabric Weight</div>
                    </div>
                    <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                        <i class="fas fa-weight-hanging fa-2x text-warning"></i>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">Cumulative kg processed at station</small>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="stat-card border border-success border-opacity-10">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value text-success">R@totalRevenue.ToString("N0")</div>
                        <div class="stat-label fw-semibold text-uppercase mt-1" style="font-size:.72rem;">Revenue Handled</div>
                    </div>
                    <div class="rounded-3 p-3 bg-success bg-opacity-10">
                        <i class="fas fa-coins fa-2x text-success"></i>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">Total order value through your queue</small>
            </div>
        </div> *@

    </div>

    @* ── Filters ──────────────────────────────────────────────────────────── *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="CompletedCycles" class="row g-2 align-items-end">

                <div class="col-12 col-md-5">
                    <label class="form-label small fw-medium text-secondary mb-1">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-color:rgba(0,0,0,.1);">
                            <i class="fas fa-search text-muted" style="font-size:.8rem;"></i>
                        </span>
                        <input type="text" name="search" value="@search"
                               class="form-control border-start-0 ps-0"
                               style="border-color:rgba(0,0,0,.1);font-size:.9rem;"
                               placeholder="Order number or customer name…" />
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <label class="form-label small fw-medium text-secondary mb-1">Service Type</label>
                    <select name="filterService" class="form-select" style="border-color:rgba(0,0,0,.1);font-size:.9rem;">
                        <option value="">All Services</option>
                        @foreach (var svc in serviceTypes)
                        {
                            <option value="@svc" selected="@(filterService == svc ? "selected" : null)">@svc</option>
                        }
                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small fw-medium text-secondary mb-1">Package</label>
                    <select name="filterTier" class="form-select" style="border-color:rgba(0,0,0,.1);font-size:.9rem;">
                        <option value="">All Tiers</option>
                        @foreach (var tier in packageTiers)
                        {
                            <option value="@tier" selected="@(filterTier == tier ? "selected" : null)">@tier</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-sm fw-semibold text-white flex-grow-1"
                            style="background:#3D5A80;border:none;border-radius:8px;font-size:.85rem;">
                        <i class="fas fa-filter me-1"></i> Filter
                    </button>
                    @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(filterService) || !string.IsNullOrEmpty(filterTier))
                    {
                        <a href="/StaffPortal/CompletedCycles"
                           class="btn btn-sm btn-outline-secondary bg-white fw-semibold"
                           style="border-radius:8px;font-size:.85rem;" title="Clear filters">
                            <i class="fas fa-xmark"></i>
                        </a>
                    }
                </div>

            </form>
        </div>
    </div>

    @* ── Results table ────────────────────────────────────────────────────── *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="fw-bold mb-0">Cycle History</h5>
                    <small class="text-muted">
                        @if (totalCycles == 0)
                        { <span>No completed cycles found</span> }
                        else
                        { <span>Showing @((currentPage - 1) * 10 + 1)–@Math.Min(currentPage * 10, totalCycles) of @totalCycles records</span> }
                    </small>
                </div>
                <span class="badge rounded-pill px-3 py-2"
                      style="background:rgba(42,157,143,.12);color:#2A9D8F;font-size:.75rem;font-weight:600;">
                    <i class="fas fa-clipboard-check me-1"></i> Wash Cycles Only
                </span>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.88rem;">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3">Ticket</th>
                            <th>Customer</th>
                            <th>Service</th>
                            <th>Package</th>
                            <th>Extras</th>
                            <th>Weight</th>
                            <th>Completed</th>
                            <th>Final Status</th>
                           @*  <th class="text-end px-4">Value</th> *@
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var order in Model)
                            {
                                var ticketId = order.OrderId.ToString().PadLeft(4, '0');

                                // Status badge styling
                                var (badgeBg, badgeText, badgeIcon) = order.Status switch
                                {
                                    OrderStatus.Completed      => ("rgba(42,157,143,.12)",  "#2A9D8F", "fa-check-circle"),
                                    OrderStatus.ReadyForPickup => ("rgba(233,196,106,.2)",  "#c07b00", "fa-box-open"),
                                    OrderStatus.OutForDelivery => ("rgba(61,90,128,.12)",   "#3D5A80", "fa-truck"),
                                    OrderStatus.Delivered      => ("rgba(34,197,94,.12)",   "#16a34a", "fa-house-circle-check"),
                                    _                          => ("rgba(107,114,128,.12)", "#6B7280", "fa-circle")
                                };

                                <tr>
                                    <td class="px-4">
                                        <span class="fw-bold font-monospace" style="color:#3D5A80;">#@ticketId</span>
                                        <div class="text-muted" style="font-size:.72rem;">@order.OrderNumber</div>
                                    </td>

                                    <td>
                                        <div class="fw-semibold text-dark">@(order.User?.FullName ?? "—")</div>
                                        <div class="text-muted" style="font-size:.75rem;">@(order.User?.PhoneNumber ?? "")</div>
                                    </td>

                                    <td>
                                        <span class="fw-medium text-dark">@order.ServiceType</span>
                                        <div class="text-muted font-monospace" style="font-size:.7rem;">
                                            @order.DetergentType
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge rounded-2 px-2 py-1 text-uppercase font-monospace"
                                              style="background:rgba(61,90,128,.1);color:#3D5A80;font-size:.68rem;">
                                            @order.PackageTier
                                        </span>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(order.Extras) || !string.IsNullOrWhiteSpace(order.SelectedExtras))
                                        {
                                            var extrasText = order.SelectedExtras ?? order.Extras ?? "";
                                            <span class="text-muted" style="font-size:.78rem;" title="@extrasText">
                                                @(extrasText.Length > 28 ? extrasText[..28] + "…" : extrasText)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted opacity-50" style="font-size:.78rem;">None</span>
                                        }
                                    </td>

                                    <td>
                                        <span class="fw-semibold" style="color:#3D5A80;">
                                            @order.WeightKg.ToString("F1") kg
                                        </span>
                                    </td>

                                    <td>
                                        <div style="font-size:.82rem;">
                                            @order.OrderDate.ToString("dd MMM yyyy")
                                        </div>
                                        <div class="text-muted" style="font-size:.72rem;">
                                            @order.OrderDate.ToString("HH:mm")
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge rounded-2 px-2 py-1 d-inline-flex align-items-center gap-1"
                                              style="background:@badgeBg;color:@badgeText;font-size:.75rem;">
                                            <i class="fas @badgeIcon" style="font-size:.65rem;"></i>
                                            @order.Status
                                        </span>
                                    </td>

                                    @* <td class="text-end px-4">
                                        <span class="fw-bold" style="color:#16a34a;">
                                            R@order.TotalAmount.ToString("N2")
                                        </span>
                                    </td> *@
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="fas fa-clock-rotate-left d-block fa-2x mb-3 opacity-25"></i>
                                    <div class="fw-semibold mb-1">No completed cycles yet</div>
                                    <small>Orders you finish processing will appear here.</small>
                                </td>
                            </tr>
                        }
                    </tbody>

                    @* Running totals footer *@
                    @if (Model != null && Model.Any())
                    {
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="5" class="px-4 py-2 text-muted small fw-semibold">
                                    Page total (@Model.Count records)
                                </td>
                                <td class="py-2 fw-bold" style="color:#3D5A80;">
                                    @Model.Sum(o => o.WeightKg).ToString("F1") kg
                                </td>
                                <td colspan="2" class="py-2"></td>
                                @* <td class="text-end px-4 py-2 fw-bold text-success">
                                    R@Model.Sum(o => o.TotalAmount).ToString("N2")
                                </td> *@
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>

        @* ── Pagination ───────────────────────────────────────────────────── *@
        @if (totalPages > 1)
        {
            <div class="card-footer bg-white border-0 px-4 py-3 d-flex justify-content-between align-items-center">
                <small class="text-muted">Page @currentPage of @totalPages</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">

                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-2 border-0"
                               style="background:@(currentPage == 1 ? "rgba(0,0,0,.05)" : "rgba(61,90,128,.1)");color:#3D5A80;"
                               href="@Url.Action("CompletedCycles", new { page = currentPage - 1, search, filterService, filterTier })">
                                <i class="fas fa-chevron-left" style="font-size:.75rem;"></i>
                            </a>
                        </li>

                        @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                        {
                            <li class="page-item">
                                <a class="page-link rounded-2 border-0 fw-semibold"
                                   style="background:@(p == currentPage ? "#3D5A80" : "rgba(61,90,128,.1)");
                                          color:@(p == currentPage ? "#fff" : "#3D5A80");
                                          min-width:32px;text-align:center;"
                                   href="@Url.Action("CompletedCycles", new { page = p, search, filterService, filterTier })">
                                    @p
                                </a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link rounded-2 border-0"
                               style="background:@(currentPage == totalPages ? "rgba(0,0,0,.05)" : "rgba(61,90,128,.1)");color:#3D5A80;"
                               href="@Url.Action("CompletedCycles", new { page = currentPage + 1, search, filterService, filterTier })">
                                <i class="fas fa-chevron-right" style="font-size:.75rem;"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        }

    </div>
</div>

