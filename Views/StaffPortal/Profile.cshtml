@model Laundry.Models.User
@{
    ViewData["Title"] = "Account Settings";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";

    // Split full name safely for individual input fields
    var nameParts = (Model.FullName ?? "Staff Member").Split(' ', 2);
    var firstName = nameParts[0];
    var lastName = nameParts.Length > 1 ? nameParts[1] : "";

    // Derive station number from ID for a nice display label
    var stationLabel = $"WS-{Model.UserId:D3}";
}

<div class="container-fluid px-0 py-2" style="max-width: 1000px;">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2 text-success"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4 alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2 text-danger"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 bg-white rounded-4 shadow-sm overflow-hidden mb-5">
        <form asp-controller="StaffPortal" asp-action="UpdateProfile" method="post">
            @Html.AntiForgeryToken()

            @* ── Profile picture header ──  *@
            <div class="p-4 border-bottom border-light">
                <h3 class="fw-bold text-dark mb-4">Account</h3>

                <div class="d-flex align-items-center gap-4 py-2">
                    <div class="position-relative">
                        @* Avatar circle  *@
                        <div class="rounded-circle d-flex align-items-center justify-content-center border border-2 border-white shadow-sm"
                             style="width:80px;height:80px;background:linear-gradient(135deg,#3D5A80,#2A9D8F);overflow:hidden;">
                            <i class="fas fa-user-hard-hat text-white fa-2x mt-1"></i>
                        </div>
                        @* Station badge  *@
                        <span class="position-absolute bottom-0 end-0 badge rounded-pill text-white fw-bold"
                              style="font-size:0.58rem;background:#2A9D8F;padding:3px 6px;letter-spacing:0.5px;">
                            @stationLabel
                        </span>
                    </div>
                    <div>
                        <h6 class="fw-bold text-dark mb-2">Profile Picture</h6>
                        <div class="d-flex gap-2 mb-2">
                            <button type="button" class="btn btn-sm text-white px-3 rounded-3 shadow-sm"
                                    style="background-color:var(--teal);border:none;"
                                    onclick="alert('Profile image uploading is linked to the central staff records system.')">
                                <i class="fas fa-upload me-1 small"></i> Upload Image
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary px-3 rounded-3 bg-white"
                                    onclick="alert('Resetting to default staff placeholder.')">
                                Remove
                            </button>
                        </div>
                        <small class="text-muted d-block" style="font-size:0.75rem;">PNGs, JPEGs and GIFs under 10 MB</small>
                    </div>
                </div>
            </div>

            @* ── Editable fields ──  *@
            <div class="p-4 border-bottom border-light bg-white">
                <div class="row g-4">

                    <div class="col-md-6">
                        <label class="form-label small fw-medium text-secondary mb-1">First Name</label>
                        <input type="text" name="firstName"
                               class="form-control staff-profile-input py-2 px-3"
                               value="@firstName" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium text-secondary mb-1">Last Name</label>
                        <input type="text" name="lastName"
                               class="form-control staff-profile-input py-2 px-3"
                               value="@lastName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium text-secondary mb-1">Mobile Phone Number</label>
                        <input type="tel" name="phoneNumber"
                               class="form-control staff-profile-input py-2 px-3"
                               value="@Model.PhoneNumber" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium text-secondary mb-1">Username Handle</label>
                        <input type="text" name="systemUsername"
                               class="form-control staff-profile-input py-2 px-3 font-monospace"
                               value="@Model.SystemUsername"
                               placeholder="e.g. staff.jane" />
                    </div>

                    @* Station ID — read-only info field  *@
                    <div class="col-md-6">
                        <label class="form-label small fw-medium text-secondary mb-1">Washing Station ID</label>
                        <div class="d-flex gap-2">
                            <input type="text"
                                   class="form-control staff-profile-input py-2 px-3 font-monospace bg-light text-muted flex-grow-1"
                                   value="@stationLabel" readonly style="cursor:not-allowed;" />
                            <span class="d-flex align-items-center px-3 rounded-3 border small fw-medium text-muted bg-white"
                                  style="font-size:0.8rem;white-space:nowrap;border-color:rgba(0,0,0,0.1)!important;">
                                <i class="fas fa-soap me-1 opacity-50"></i> Auto-assigned
                            </span>
                        </div>
                        <small class="text-muted d-block mt-1" style="font-size:0.75rem;">Your permanent washing station identifier</small>
                    </div>

                    @* Email — read-only, admin changes only  *@
                    <div class="col-md-6">
                        <label class="form-label small fw-medium text-secondary mb-1">Email</label>
                        <div class="d-flex gap-2">
                            <input type="email"
                                   class="form-control staff-profile-input py-2 px-3 bg-light text-muted flex-grow-1"
                                   value="@Model.Email" readonly style="cursor:not-allowed;" />
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary px-3 rounded-3 bg-white border border-secondary border-opacity-20 small fw-medium"
                                    style="white-space:nowrap;font-size:0.82rem;"
                                    onclick="alert('Email changes must be processed through the admin office.')">
                                Edit Email
                            </button>
                        </div>
                        <small class="text-muted d-block mt-1" style="font-size:0.75rem;">Used to log in to your staff account</small>
                    </div>

                </div>
            </div>

            @* ── Password section ──  *@
            <div class="p-4 border-bottom border-light bg-white">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <h6 class="fw-bold text-dark mb-1">Password</h6>
                        <p class="text-muted small mb-0" style="font-size:0.8rem;">
                            Secure your account with a strong password. Contact an admin if you're locked out.
                        </p>
                    </div>
                    <div>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary px-3 py-2 bg-white border border-secondary border-opacity-20 fw-semibold"
                                style="font-size:0.8rem;border-radius:8px;"
                                onclick="alert('A password reset link will be sent to your registered email address.')">
                            Change Password
                        </button>
                    </div>
                </div>
            </div>

            @* ── Account info strip ──  *@
            <div class="p-4 border-bottom border-light bg-white">
                <h6 class="fw-bold text-dark mb-3">Account Info</h6>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-2 d-flex align-items-center justify-content-center"
                                 style="width:34px;height:34px;background:rgba(42,157,143,0.1);flex-shrink:0;">
                                <i class="fas fa-calendar-plus text-teal" style="color:#2A9D8F;font-size:0.85rem;"></i>
                            </div>
                            <div>
                                <div class="small fw-semibold text-dark" style="font-size:0.82rem;">Member Since</div>
                                <div class="text-muted" style="font-size:0.78rem;">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-2 d-flex align-items-center justify-content-center"
                                 style="width:34px;height:34px;background:rgba(61,90,128,0.1);flex-shrink:0;">
                                <i class="fas fa-clock" style="color:#3D5A80;font-size:0.85rem;"></i>
                            </div>
                            <div>
                                <div class="small fw-semibold text-dark" style="font-size:0.82rem;">Last Login</div>
                                <div class="text-muted" style="font-size:0.78rem;">
                                    @(Model.LastLoginAt.HasValue ? Model.LastLoginAt.Value.ToString("dd MMM yyyy · HH:mm") : "—")
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-2 d-flex align-items-center justify-content-center"
                                 style="width:34px;height:34px;background:rgba(42,157,143,0.1);flex-shrink:0;">
                                <i class="fas fa-circle-check" style="color:#2A9D8F;font-size:0.85rem;"></i>
                            </div>
                            <div>
                                <div class="small fw-semibold text-dark" style="font-size:0.82rem;">Account Status</div>
                                <div class="fw-bold" style="font-size:0.78rem;color:#2A9D8F;">
                                    @(Model.IsActive ? "Active" : "Inactive")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Save / cancel footer ──  *@
            <div class="p-4 bg-light bg-opacity-40 d-flex justify-content-end align-items-center gap-2 border-top border-light">
                <a href="/StaffPortal/Index"
                   class="btn btn-sm btn-light border bg-white text-secondary fw-semibold px-4 py-2"
                   style="border-radius:10px;font-size:0.85rem;">
                    Cancel
                </a>
                <button type="submit"
                        class="btn btn-sm text-white px-4 py-2 fw-semibold shadow-sm btn-save-staff"
                        style="background-color:var(--teal);border:none;border-radius:10px;font-size:0.85rem;">
                    Save Changes
                </button>
            </div>

        </form>
    </div>
</div>

<style>
    .staff-profile-input {
        background-color: #ffffff !important;
        border: 1px solid rgba(0,0,0,0.08) !important;
        border-radius: 10px !important;
        color: var(--text-dark) !important;
        font-size: 0.9rem !important;
        font-weight: 400 !important;
        transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
    }

    .staff-profile-input:focus {
        border-color: var(--indigo) !important;
        box-shadow: 0 0 0 3px rgba(61,90,128,0.12) !important;
        outline: none !important;
    }

    .btn-save-staff {
        transition: all 0.2s ease-in-out !important;
    }

    .btn-save-staff:hover {
        background-color: var(--indigo-dark) !important;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(61,90,128,0.25) !important;
    }
</style>
