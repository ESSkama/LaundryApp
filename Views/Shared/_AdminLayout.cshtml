<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SUDS & SPIN Admin</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Toastr + Charts -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --teal: #2A9D8F;
            --teal-dark: #1E6B61;
            --deep-navy: #264653;
            --cream: #F4F1DE;
            --text-dark: #3D4452;
            --text-soft: #6B7280;
            --white: #FFFFFF;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0f2f5;
            color: var(--text-dark);
        }

        /* Admin Sidebar */
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 280px;
            background: linear-gradient(180deg, var(--deep-navy) 0%, #1a3a4a 100%);
            color: white;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            transition: all 0.3s;
        }

            .admin-sidebar .brand {
                padding: 24px;
                text-align: center;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                margin-bottom: 24px;
            }

                .admin-sidebar .brand .brand-icon {
                    width: 50px;
                    height: 50px;
                    background: var(--teal);
                    border-radius: 12px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin: 0 auto 12px;
                }

                .admin-sidebar .brand h3 {
                    font-size: 1.2rem;
                    margin-bottom: 0;
                }

            .admin-sidebar .nav-link {
                color: rgba(255,255,255,0.8);
                padding: 12px 24px;
                display: flex;
                align-items: center;
                gap: 12px;
                transition: all 0.3s;
            }

                .admin-sidebar .nav-link:hover,
                .admin-sidebar .nav-link.active {
                    background: rgba(42,157,143,0.2);
                    color: white;
                    border-left: 3px solid var(--teal);
                }

                .admin-sidebar .nav-link i {
                    width: 20px;
                }

        /* Admin Main Content */
        .admin-content {
            flex: 1;
            margin-left: 280px;
            padding: 24px;
        }

        /* Top Bar */
        .admin-top-bar {
            background: white;
            padding: 12px 24px;
            border-radius: 12px;
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        /* Stats Cards */
        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
            transition: transform 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
            }

            .stat-card .stat-icon {
                width: 48px;
                height: 48px;
                background: rgba(42,157,143,0.1);
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .stat-card .stat-value {
                font-size: 1.8rem;
                font-weight: 700;
                color: var(--teal);
            }

        /* Tables */
        .admin-table {
            background: white;
            border-radius: 16px;
            overflow: hidden;
        }

            .admin-table th {
                background: #f8f9fa;
                padding: 12px 16px;
                font-weight: 600;
            }

            .admin-table td {
                padding: 12px 16px;
                vertical-align: middle;
            }

        /* Status Badges */
        .status-badge {
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }

            .status-badge.pending {
                background: #ffc107;
                color: #856404;
            }

            .status-badge.confirmed {
                background: #28a745;
                color: white;
            }

            .status-badge.assigned {
                background: #17a2b8;
                color: white;
            }

            .status-badge.enroute {
                background: #fd7e14;
                color: white;
            }

            .status-badge.progress {
                background: #6c757d;
                color: white;
            }

            .status-badge.delivered {
                background: #28a745;
                color: white;
            }

            .status-badge.cancelled {
                background: #dc3545;
                color: white;
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .admin-sidebar {
                width: 70px;
            }

                .admin-sidebar .brand h3,
                .admin-sidebar .nav-link span {
                    display: none;
                }

            .admin-content {
                margin-left: 70px;
            }
        }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <div class="admin-sidebar">
            <div class="brand">
                <div class="brand-icon">
                    <i class="fas fa-tshirt fa-2x"></i>
                </div>
                <h3>SUDS & SPIN</h3>
                <small>Admin Panel</small>
            </div>
            <nav class="nav flex-column">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" href="/Admin/Dashboard">
                    <i class="fas fa-chart-line"></i> <span>Dashboard</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageOrders" ? "active" : "")" href="/Admin/ManageOrders">
                    <i class="fas fa-clipboard-list"></i> <span>Orders</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageUsers" ? "active" : "")" href="/Admin/ManageUsers">
                    <i class="fas fa-users"></i> <span>Customers</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Drivers" ? "active" : "")" href="/Admin/Drivers">
                    <i class="fas fa-truck"></i> <span>Drivers</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Staff" ? "active" : "")" href="/Admin/Staff">
                    <i class="fas fa-user-tie"></i> <span>Laundry Staff</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Subscriptions" ? "active" : "")" href="/Admin/Subscriptions">
                    <i class="fas fa-crown"></i> <span>Subscriptions</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Reports" ? "active" : "")" href="/Admin/Reports">
                    <i class="fas fa-chart-bar"></i> <span>Reports</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Logs" ? "active" : "")" href="/Admin/Logs">
                    <i class="fas fa-history"></i> <span>Activity Logs</span>
                </a>
                <hr class="my-2" style="border-color: rgba(255,255,255,0.1);">
                <a class="nav-link" href="/">
                    <i class="fas fa-store"></i> <span>Website</span>
                </a>
                <a class="nav-link text-danger" href="#" onclick="document.getElementById('logoutForm').submit();">
                    <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
                </a>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="admin-content">
            <div class="admin-top-bar">
                <div>
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                    <small class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</small>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="notification-bell position-relative">
                        <i class="fas fa-bell fa-lg" style="cursor: pointer;" id="adminNotificationBell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="adminNotificationCount" style="display: none;">0</span>
                    </div>
                    <div>
                        <i class="fas fa-user-circle fa-2x"></i>
                        <span class="ms-2">@User.Identity.Name.Split('@')[0]</span>
                    </div>
                </div>
            </div>

            @RenderBody()
        </div>
    </div>

    <form id="logoutForm" action="/Account/Logout" method="post" style="display:none;"></form>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "5000"
        };

        // SignalR Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.start().then(() => {
            console.log("Admin SignalR connected");
            connection.invoke("JoinAdminGroup");
        }).catch(err => console.error("SignalR error:", err));

        connection.on("ReceiveNotification", (title, message, orderId) => {
            toastr.info(message, title);
            updateAdminNotificationCount();
        });

        connection.on("NewOrderAlert", (orderNumber, customerName) => {
            toastr.warning(`New order #${orderNumber} from ${customerName}`, "New Order!");
            updateAdminNotificationCount();
        });

        function updateAdminNotificationCount() {
            $.get('/Admin/GetUnreadCount', function(count) {
                if (count > 0) {
                    $('#adminNotificationCount').text(count).show();
                } else {
                    $('#adminNotificationCount').hide();
                }
            });
        }

        updateAdminNotificationCount();
        setInterval(updateAdminNotificationCount, 30000);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>