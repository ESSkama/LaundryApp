<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SUDS & SPIN | Gqeberha's Premium Laundry Service</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <style>
        :root {
            --teal: #2A9D8F;
            --teal-dark: #1E6B61;
            --teal-light: #5EC4B6;
            --deep-navy: #264653;
            --cream: #F4F1DE;
            --sand: #E9C46A;
            --warm-gray: #E8E0D5;
            --text-dark: #3D4452;
            --text-soft: #6B7280;
            --white: #FFFFFF;
            --success: #2A9D8F;
            --warning: #E9C46A;
            --error: #E76F51;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--cream);
            color: var(--text-dark);
            line-height: 1.5;
        }

        /* Top Bar */
        .top-bar {
            background: var(--deep-navy);
            color: white;
            padding: 8px 0;
            font-size: 0.8rem;
        }

        /* Navigation */
        .navbar {
            background: white;
            padding: 0.8rem 0;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            transition: all 0.3s ease;
        }

            .navbar.scrolled {
                padding: 0.5rem 0;
                box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-icon {
            position: relative;
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .brand-icon i {
                color: white;
                font-size: 1.4rem;
            }

        .brand-text {
            line-height: 1.2;
        }

        .brand-name {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: block;
        }

        .brand-tagline {
            font-size: 0.7rem;
            color: var(--text-soft);
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
            color: var(--deep-navy);
            margin: 0 4px;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: var(--teal);
            }

        .btn-login, .btn-signup {
            padding: 8px 20px;
            border-radius: 50px;
            transition: all 0.3s ease;
        }

        .btn-login {
            color: var(--teal);
            border: 2px solid var(--teal);
        }

            .btn-login:hover {
                background: var(--teal);
                color: white;
            }

        .btn-signup {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
        }

            .btn-signup:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(42,157,143,0.3);
                color: white;
            }

        /* Hero Section */
        .hero {
            padding: 80px 0;
            background: linear-gradient(135deg, var(--cream) 0%, white 100%);
            position: relative;
            overflow: hidden;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .hero-badge {
            display: inline-block;
            background: rgba(42,157,143,0.1);
            color: var(--teal);
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 24px;
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 700;
            line-height: 1.2;
            color: var(--deep-navy);
            margin-bottom: 24px;
        }

        .hero-highlight {
            color: var(--teal);
        }

        .hero-description {
            font-size: 1.1rem;
            color: var(--text-soft);
            margin-bottom: 32px;
            max-width: 500px;
        }

        .hero-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

            .btn-primary-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(42,157,143,0.3);
                color: white;
            }

        .btn-outline-custom {
            background: transparent;
            border: 2px solid var(--teal);
            color: var(--teal);
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-outline-custom:hover {
                background: var(--teal);
                color: white;
            }

        .trust-badge {
            background: white;
            border-radius: 20px;
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            max-width: 320px;
            margin-left: auto;
            position: relative;
            z-index: 2;
        }

        .trust-icon {
            width: 60px;
            height: 60px;
            background: var(--teal);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
            font-weight: 700;
        }

        .trust-text strong {
            display: block;
            font-size: 1.2rem;
            color: var(--deep-navy);
        }

        .trust-text span {
            font-size: 0.85rem;
            color: var(--text-soft);
        }

        /* Section Styles */
        .section {
            padding: 80px 0;
        }

        .bg-light {
            background: white;
        }

        .section-header {
            text-align: center;
            margin-bottom: 56px;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--deep-navy);
            margin-bottom: 16px;
        }

        .section-subtitle {
            color: var(--text-soft);
            font-size: 1.1rem;
        }

        /* Steps Grid */
        .steps-grid {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
        }

        .step-card {
            flex: 1;
            background: white;
            border-radius: 24px;
            padding: 40px 24px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            transition: all 0.3s ease;
        }

            .step-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.1);
            }

        .step-number {
            font-size: 3rem;
            font-weight: 800;
            color: rgba(42,157,143,0.15);
            margin-bottom: 16px;
        }

        .step-icon {
            width: 70px;
            height: 70px;
            background: rgba(42,157,143,0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

            .step-icon i {
                font-size: 2rem;
                color: var(--teal);
            }

        .step-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--deep-navy);
            margin-bottom: 12px;
        }

        .step-description {
            color: var(--text-soft);
            font-size: 0.9rem;
        }

        .step-arrow {
            color: var(--teal);
            font-size: 1.5rem;
            display: flex;
            align-items: center;
        }

        /* Services Grid */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .service-card {
            background: white;
            border-radius: 24px;
            padding: 40px 24px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            transition: all 0.3s ease;
            position: relative;
        }

            .service-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.1);
            }

            .service-card.featured {
                border: 2px solid var(--teal);
                transform: scale(1.02);
            }

        .service-badge {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--teal);
            color: white;
            padding: 4px 16px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .service-icon {
            width: 70px;
            height: 70px;
            background: rgba(42,157,143,0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

            .service-icon i {
                font-size: 2rem;
                color: var(--teal);
            }

        .service-name {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--deep-navy);
            margin-bottom: 8px;
        }

        .service-price {
            font-size: 2rem;
            font-weight: 700;
            color: var(--teal);
            margin-bottom: 8px;
        }

        .service-unit {
            font-size: 0.8rem;
            font-weight: 400;
            color: var(--text-soft);
        }

        .service-desc {
            font-size: 0.85rem;
            color: var(--text-soft);
            margin: 12px 0 20px;
        }

        .service-link {
            color: var(--teal);
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .service-link:hover {
                gap: 8px;
            }

        /* Plans Grid */
        .plans-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .plan-card {
            background: white;
            border-radius: 24px;
            padding: 40px 24px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            transition: all 0.3s ease;
            position: relative;
        }

            .plan-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.1);
            }

            .plan-card.featured {
                border: 2px solid var(--teal);
                transform: scale(1.02);
            }

        .plan-badge {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--teal);
            color: white;
            padding: 4px 16px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .plan-name {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--deep-navy);
            margin-bottom: 12px;
        }

        .plan-price {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--teal);
            margin-bottom: 20px;
        }

        .plan-period {
            font-size: 0.8rem;
            font-weight: 400;
            color: var(--text-soft);
        }

        .plan-features {
            list-style: none;
            padding: 0;
            margin: 24px 0;
        }

            .plan-features li {
                padding: 8px 0;
                font-size: 0.85rem;
                color: var(--text-soft);
            }

            .plan-features i {
                color: var(--teal);
                margin-right: 8px;
                font-size: 0.75rem;
            }

        .plan-link {
            color: var(--teal);
            text-decoration: none;
            font-weight: 500;
            display: inline-block;
        }

            .plan-link.featured-link {
                background: var(--teal);
                color: white;
                padding: 12px 28px;
                border-radius: 50px;
            }

                .plan-link.featured-link:hover {
                    background: var(--teal-dark);
                    text-decoration: none;
                    color: white;
                }

        /* FAQ Section */
        .faq-grid {
            max-width: 800px;
            margin: 0 auto;
        }

        .faq-item {
            background: white;
            border-radius: 16px;
            margin-bottom: 16px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 24px;
            cursor: pointer;
            font-weight: 600;
            color: var(--deep-navy);
            transition: all 0.3s ease;
        }

            .faq-question:hover {
                background: #f8f9fa;
            }

            .faq-question::after {
                content: '+';
                font-size: 1.2rem;
                color: var(--teal);
            }

        .faq-item.active .faq-question::after {
            content: '−';
        }

        .faq-answer {
            padding: 0 24px;
            max-height: 0;
            overflow: hidden;
            transition: all 0.3s ease;
            color: var(--text-soft);
            line-height: 1.6;
        }

        .faq-item.active .faq-answer {
            padding: 0 24px 20px 24px;
            max-height: 200px;
        }

        /* Footer */
        .footer {
            background: var(--deep-navy);
            color: white;
            padding: 60px 0 20px;
            margin-top: 0;
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

            .footer-brand i {
                font-size: 1.8rem;
            }

        .footer-about {
            opacity: 0.7;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        .footer h6 {
            font-weight: 600;
            margin-bottom: 20px;
        }

        .footer ul {
            list-style: none;
            padding: 0;
        }

            .footer ul li {
                margin-bottom: 10px;
            }

                .footer ul li a {
                    color: rgba(255,255,255,0.7);
                    text-decoration: none;
                    transition: all 0.3s ease;
                }

                    .footer ul li a:hover {
                        color: white;
                        padding-left: 5px;
                    }

        .contact-info li {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            font-size: 0.85rem;
        }

        .contact-info i {
            width: 20px;
            color: var(--teal);
        }

        .contact-info a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
        }

            .contact-info a:hover {
                color: white;
            }

        .newsletter-form {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

            .newsletter-form input {
                flex: 1;
                background: rgba(255,255,255,0.1);
                border: none;
                padding: 12px 16px;
                border-radius: 12px;
                color: white;
            }

                .newsletter-form input::placeholder {
                    color: rgba(255,255,255,0.5);
                }

        .btn-subscribe {
            background: var(--teal);
            border: none;
            width: 45px;
            border-radius: 12px;
            color: white;
            transition: all 0.3s ease;
        }

            .btn-subscribe:hover {
                background: var(--teal-dark);
            }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 20px;
            margin-top: 40px;
            text-align: center;
            font-size: 0.85rem;
            opacity: 0.7;
        }

        /* Animations */
        .fade-in-up {
            animation: fadeInUp 0.6s ease forwards;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .hero-title {
                font-size: 2rem;
            }

            .hero-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .services-grid, .plans-grid {
                grid-template-columns: 1fr;
            }

            .steps-grid {
                flex-direction: column;
            }

            .step-arrow {
                transform: rotate(90deg);
                justify-content: center;
            }

            .section-title {
                font-size: 1.8rem;
            }

            .service-card.featured, .plan-card.featured {
                transform: scale(1);
            }
        }
    </style>
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <small><i class="fas fa-phone-alt me-2"></i> +27 41 123 4567</small>
                    <span class="mx-2">|</span>
                    <small><i class="fas fa-envelope me-2"></i> hello@sudsandspin.co.za</small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <small><i class="fas fa-clock me-2"></i> Mon-Sat: 8am - 5pm</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="navbar navbar-expand-lg sticky-top" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="brand-icon">
                    <i class="fas fa-tshirt"></i>
                </div>
                <div class="brand-text">
                    <span class="brand-name">SUDS & SPIN</span>
                    <span class="brand-tagline">Gqeberha's finest</span>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#how-it-works">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#pricing">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" href="#faq">FAQ</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Order/Create">New Order</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Order/MyOrders">My Orders</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i> @User.Identity.Name.Split('@')[0]
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Order/MyOrders"><i class="fas fa-box"></i> My Orders</a></li>
                                <li><a class="dropdown-item" href="/Subscription/Manage"><i class="fas fa-gem"></i> Subscription</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" onclick="document.getElementById('logoutForm').submit();"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Account/Login">Sign In</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/Register">Get Started</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <form id="logoutForm" action="/Account/Logout" method="post" style="display:none;"></form>

    <!-- MAIN CONTENT - @RenderBody() 
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <div class="footer-brand">
                        <i class="fas fa-tshirt"></i>
                        <span>SUDS & SPIN</span>
                    </div>
                    <p class="footer-about">Gqeberha's premier laundry service. We care for your clothes..</p>
                </div>
                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6>Quick Links</h6>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/Order/Create">New Order</a></li>
                        <li><a href="/Order/MyOrders">My Orders</a></li>
                        <li><a href="/Subscription/Manage">Subscription</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h6>Contact Us</h6>
                    <ul class="contact-info">
                        <li><i class="fas fa-phone-alt"></i> <a href="tel:+27411234567">+27 41 123 4567</a></li>
                        <li><i class="fas fa-envelope"></i> <a href="mailto:hello@sudsandspin.co.za">hello@sudsandspin.co.za</a></li>
                        <li><i class="fas fa-map-marker-alt"></i> 123 Main Road, Walmer<br>Gqeberha (Port Elizabeth), 6070</li>
                        <li><i class="fas fa-clock"></i> Mon-Sat: 8am - 5pm</li>
                        <li><i class="fas fa-clock"></i> Sunday: Closed</li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6>Newsletter</h6>
                    <p class="small">Subscribe to our newsletter for exclusive offers and tips & tricks to help you save your clothes.</p>
                    <form method="post" action="/Home/Subscribe" class="newsletter-form">
                        @Html.AntiForgeryToken()
                        <input type="email" name="email" placeholder="Your email address" required>
                        <button type="submit" class="btn-subscribe"><i class="fas fa-paper-plane"></i></button>
                    </form>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year SUDS & SPIN —  All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS animations
        AOS.init({
            duration: 800,
            once: true,
            offset: 100
        });

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('mainNavbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // FAQ Accordion
        document.querySelectorAll('.faq-question').forEach(question => {
            question.addEventListener('click', () => {
                const faqItem = question.parentElement;
                faqItem.classList.toggle('active');
            });
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href !== "#" && href !== "#" && !href.startsWith('/')) {
                    const target = document.querySelector(href);
                    if (target) {
                        e.preventDefault();
                        target.scrollIntoView({ behavior: 'smooth' });
                    }
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>