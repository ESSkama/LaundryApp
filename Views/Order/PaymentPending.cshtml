@using Newtonsoft.Json
@model Laundry.Models.Order
@{
    ViewData["Title"] = "Payment Required - SUDS & SPIN";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";

    var paymentMethod = ViewBag.PaymentMethod as string ?? Context.Request.Query["method"];
    var eftInstructionJson = TempData["EFTInstruction"] as string;
    var eftInstruction = eftInstructionJson != null ? JsonConvert.DeserializeObject<Laundry.Services.PaymentInstruction>(eftInstructionJson) : null;
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="form-container text-center">
                @if (paymentMethod == "eft")
                {
                    <i class="fas fa-university fa-4x" style="color: var(--teal);"></i>
                    <h2 class="mt-3">EFT Payment Required</h2>
                    <p class="text-muted">Complete your payment to confirm your order</p>

                    <div class="alert alert-warning">
                        <i class="fas fa-clock me-2"></i>
                        Please complete payment within <strong>24 hours</strong> to avoid order cancellation.
                    </div>

                    <div class="card bg-light mt-4">
                        <div class="card-body text-start">
                            <h5 class="mb-3">Bank Details</h5>
                            <table class="table table-borderless">
                                <tr>
                                    <td width="40%"><strong>Bank Name:</strong></td>
                                    <td>@eftInstruction?.BankName</td>
                                </tr>
                                <tr>
                                    <td><strong>Account Name:</strong></td>
                                    <td>@eftInstruction?.AccountName</td>
                                </tr>
                                <tr>
                                    <td><strong>Account Number:</strong></td>
                                    <td>@eftInstruction?.AccountNumber</td>
                                </tr>
                                <tr>
                                    <td><strong>Branch Code:</strong></td>
                                    <td>@eftInstruction?.BranchCode</td>
                                </tr>
                                <tr>
                                    <td><strong>Reference:</strong></td>
                                    <td><strong class="text-primary">@eftInstruction?.Reference</strong></td>
                                </tr>
                                <tr>
                                    <td><strong>Amount Due:</strong></td>
                                    <td><strong class="text-success">@eftInstruction?.Amount.ToString("C")</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="card bg-light mt-3">
                        <div class="card-body">
                            <h6>Instructions:</h6>
                            <ul>
                                @if (eftInstruction?.InstructionsList != null)
                                {
                                    foreach (var instruction in eftInstruction.InstructionsList)
                                    {
                                        <li>@instruction</li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a href="/Order/Details/@Model?.OrderId" class="btn-outline-custom">
                            <i class="fas fa-eye"></i> View Order
                        </a>
                        <button onclick="copyBankDetails()" class="btn-primary-custom ms-2">
                            <i class="fas fa-copy"></i> Copy Bank Details
                        </button>
                    </div>

                    <div class="mt-4">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            After payment, our team will verify and confirm your order within 24 hours.
                        </div>
                        <a href="/Order/Details/@Model?.OrderId" class="btn-primary-custom w-100">
                            <i class="fas fa-check-circle"></i> Go to Order Details
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
        function copyBankDetails() {
            const details = `Bank: @(eftInstruction?.BankName ?? "")
    Account Name: @(eftInstruction?.AccountName ?? "")
    Account Number: @(eftInstruction?.AccountNumber ?? "")
    Branch Code: @(eftInstruction?.BranchCode ?? "")
    Reference: @(eftInstruction?.Reference ?? "")
    Amount: @(eftInstruction?.Amount.ToString("C") ?? "R0.00")`;

            navigator.clipboard.writeText(details);
            alert('Bank details copied to clipboard!');
        }
</script>