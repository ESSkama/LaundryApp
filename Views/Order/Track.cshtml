@model Laundry.Models.Order
@{
    ViewData["Title"] = $"Track Order #{Model?.OrderNumber} - SUDS & SPIN";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="form-container">
                <div class="text-center mb-4">
                    <i class="fas fa-map-marker-alt fa-3x" style="color: var(--teal);"></i>
                    <h2 class="mt-3">Track Order #@Model?.OrderNumber</h2>
                    <p class="text-muted">Real-time tracking of your laundry order</p>
                </div>

                @if (Model == null)
                {
                    <div class="alert alert-danger">Order not found.</div>
                }
                else
                {
                    <!-- Order Progress Timeline -->
                    <div class="timeline mb-5">
                        <div class="timeline-step @(Model.Status >= Laundry.Models.OrderStatus.PaymentConfirmed ? "completed" : "")">
                            <div class="timeline-icon"><i class="fas fa-credit-card"></i></div>
                            <div class="timeline-content">
                                <h6>Payment Confirmed</h6>
                                @if (Model.Status >= Laundry.Models.OrderStatus.PaymentConfirmed)
                                {
                                    <small>@Model.OrderDate.ToString("dd MMM yyyy, HH:mm")</small>
                                }
                            </div>
                        </div>
                        <div class="timeline-step @(Model.Status >= Laundry.Models.OrderStatus.PickupAssigned ? "completed" : "")">
                            <div class="timeline-icon"><i class="fas fa-truck"></i></div>
                            <div class="timeline-content">
                                <h6>Pickup Assigned</h6>
                                @if (Model.Status >= Laundry.Models.OrderStatus.PickupAssigned && Model.PickupDate.HasValue)
                                {
                                    <small>@Model.PickupDate.Value.ToString("dd MMM yyyy, HH:mm")</small>
                                }
                            </div>
                        </div>
                        <div class="timeline-step @(Model.Status >= Laundry.Models.OrderStatus.PickedUp ? "completed" : "")">
                            <div class="timeline-icon"><i class="fas fa-box"></i></div>
                            <div class="timeline-content">
                                <h6>Picked Up</h6>
                                @if (Model.Status >= Laundry.Models.OrderStatus.PickedUp && Model.PickupDate.HasValue)
                                {
                                    <small>@Model.PickupDate.Value.ToString("dd MMM yyyy, HH:mm")</small>
                                }
                            </div>
                        </div>
                        <div class="timeline-step @(Model.Status >= Laundry.Models.OrderStatus.WashingInProgress ? "completed" : "")">
                            <div class="timeline-icon"><i class="fas fa-water"></i></div>
                            <div class="timeline-content">
                                <h6>Washing in Progress</h6>
                            </div>
                        </div>
                        <div class="timeline-step @(Model.Status >= Laundry.Models.OrderStatus.OutForDelivery ? "completed" : "")">
                            <div class="timeline-icon"><i class="fas fa-shipping-fast"></i></div>
                            <div class="timeline-content">
                                <h6>Out for Delivery</h6>
                                @if (Model.EtaMinutes.HasValue)
                                {
                                    <small>ETA: @Model.EtaMinutes minutes</small>
                                }
                            </div>
                        </div>
                        <div class="timeline-step @(Model.Status >= Laundry.Models.OrderStatus.Delivered ? "completed" : "")">
                            <div class="timeline-icon"><i class="fas fa-home"></i></div>
                            <div class="timeline-content">
                                <h6>Delivered</h6>
                                @if (Model.Status >= Laundry.Models.OrderStatus.Delivered && Model.DeliveryDate.HasValue)
                                {
                                    <small>@Model.DeliveryDate.Value.ToString("dd MMM yyyy, HH:mm")</small>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Current Status Info -->
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Current Status:</strong> @Model.Status.ToString()
                        @if (!string.IsNullOrEmpty(Model.DriverName))
                        {
                            <br />
                            <i class="fas fa-truck me-1"></i>
                            <strong>Driver:</strong> @Model.DriverName <span>(Phone: @Model.DriverPhone)</span>
                        }
                        @if (Model.EtaMinutes.HasValue && Model.EtaMinutes > 0)
                        {
                            <br />
                            <i class="fas fa-clock me-1"></i>
                           <strong>ETA:</strong> @($"{Model.EtaMinutes.Value} minutes")
                        }
                    </div>

                    <div class="text-center mt-4">
                        <a href="/Order/Details/@Model.OrderId" class="btn-outline-custom">
                            <i class="fas fa-arrow-left"></i> Back to Order Details
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 30px;
    }

    .timeline:before {
        content: '';
        position: absolute;
        left: 20px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #e9ecef;
    }

    .timeline-step {
        position: relative;
        margin-bottom: 30px;
        display: flex;
        align-items: flex-start;
        gap: 15px;
    }

    .timeline-icon {
        width: 40px;
        height: 40px;
        background: #f8f9fa;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        transition: all 0.3s ease;
    }

    .timeline-step.completed .timeline-icon {
        background: var(--teal);
        color: white;
    }

    .timeline-content {
        flex: 1;
    }

    .form-container {
        background: white;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }
</style>