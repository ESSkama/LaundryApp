@model List<Laundry.Models.Order>
@{
    ViewData["Title"] = "Route Management Unit";
    Layout = "~/Views/Shared/_DriverLayout.cshtml"; 

    var pickupCount = ViewBag.ActivePickupsCount ?? 0;
    var deliveryCount = ViewBag.ActiveDeliveriesCount ?? 0;
}

<div class="admin-dashboard p-1">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Capacity Summary Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="stat-card border border-primary border-opacity-10">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value text-primary">@pickupCount</div>
                        <div class="stat-label fw-semibold text-uppercase tracking-wider mt-1" style="font-size: 0.72rem;">Assigned Collections</div>
                    </div>
                    <div class="stat-icon bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="fas fa-truck-loading fa-2x text-primary"></i>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">Pending customer collection points</small>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card border border-success border-opacity-10">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value text-success">@deliveryCount</div>
                        <div class="stat-label fw-semibold text-uppercase tracking-wider mt-1" style="font-size: 0.72rem;">Pending Drops</div>
                    </div>
                    <div class="stat-icon bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="fas fa-shipping-fast fa-2x text-success"></i>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">Processed clean loads ready for home drop-off</small>
            </div>
        </div>
    </div>

    <!-- Active Manifest Work Data Grid -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">My Active Route Manifest</h5>
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-2.5 py-1.5 rounded-2 small">
                    <i class="fas fa-circle me-1" style="font-size: 0.6rem;"></i> On Duty / Connected
                </span>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ticket ID</th>
                            <th>Run Type</th>
                            <th>Client Profile</th>
                            <th>Target Destination</th>
                            <th>Assigned Timestamp</th>
                            <th>Tracking State</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var job in Model)
                            {
                                var friendlyOrderId = job.OrderId.ToString().PadLeft(4, '0');
                                var isDeliveryDrop = (job.Status == Laundry.Models.OrderStatus.OutForDelivery);
                                
                                <tr>
                                    <td><span class="text-secondary fw-bold">#@friendlyOrderId</span></td>
                                    <td>
                                        <span class="badge @(isDeliveryDrop ? "bg-success" : "bg-primary") rounded-2 px-2 py-1 text-uppercase font-monospace fw-bold" style="font-size: 0.65rem;">
                                            @(isDeliveryDrop ? "Delivery" : "Collection")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">@(job.User?.FullName ?? "FreshDrop Client")</div>
                                        <small class="text-muted font-monospace" style="font-size: 0.72rem;">@job.User?.PhoneNumber</small>
                                    </td>
                                    <td>
                                        <div class="text-dark fw-medium small" style="max-width: 180px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@(isDeliveryDrop ? job.DeliveryAddress : job.PickupAddress)">
                                            @(isDeliveryDrop ? job.DeliveryAddress : job.PickupAddress)
                                        </div>
                                    </td>
                                    <td>
                                        @if (job.DriverAssignedAt.HasValue)
                                        {
                                            <div class="fw-bold text-dark small">@job.DriverAssignedAt.Value.ToString("dd MMM yyyy")</div>
                                            <div class="text-muted font-monospace" style="font-size: 0.75rem;">@job.DriverAssignedAt.Value.ToString("hh:mm tt")</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">-</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var statusBadgeClass = job.Status switch
                                            {
                                                Laundry.Models.OrderStatus.PickupAssigned => "bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20",
                                                Laundry.Models.OrderStatus.DriverEnRoute => "bg-info bg-opacity-10 text-info border border-info border-opacity-20",
                                                Laundry.Models.OrderStatus.PickedUp => "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20",
                                                Laundry.Models.OrderStatus.OutForDelivery => "bg-success bg-opacity-10 text-success border border-success border-opacity-20",
                                                _ => "bg-light text-muted border"
                                            };
                                        }
                                        <span class="badge @statusBadgeClass rounded-2 px-2.5 py-1.5">@job.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <a href="/Driver/Details/@job.OrderId" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-medium" style="font-size: 0.8rem;">
                                            View Order <i class="fas fa-chevron-right ms-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted small">
                                    <i class="fas fa-clipboard-check d-block fa-2x mb-2 text-muted opacity-40"></i>
                                    No active tasks are currently mapped to your vehicle route manifest.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>