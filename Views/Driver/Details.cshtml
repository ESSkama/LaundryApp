@model Laundry.Models.Order
@{
    ViewData["Title"] = $"Order Execution Specification #{Model.OrderId.ToString().PadLeft(4, '0')}";
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
    
    var isDelivery = (Model.Status == Laundry.Models.OrderStatus.OutForDelivery);
}

<div class="admin-dashboard p-1">
    <div class="mb-3">
        <a href="/Driver/Index" class="btn btn-sm btn-link text-decoration-none text-secondary p-0">
            <i class="fas fa-arrow-left me-1"></i> Back to Manifest Route Sheet
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 text-center small">
            <i class="fas fa-check-circle me-1.5"></i> @TempData["Success"]
        </div>
    }

    <div class="row g-4">
        <!-- LEFT: Customer Information & Delivery Address Details -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold text-dark mb-0"><i class="fas fa-map-marked-alt text-teal me-2"></i>Location & Destination Spec</h5>
                </div>
                <div class="card-body p-4">
                    <div class="p-3 bg-light rounded-3 mb-4 border">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 0.68rem; letter-spacing: 0.5px;">Target Client</small>
                        <h5 class="fw-bold text-dark mb-1">@(Model.User?.FullName ?? "FreshDrop Client Profile")</h5>
                        <div class="small text-secondary"><i class="fas fa-phone-alt me-1.5 text-muted"></i>Mobile phone: <strong>@Model.User?.PhoneNumber</strong></div>
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold text-secondary small text-uppercase mb-2">Transit Destination Address</h6>
                        <div class="p-3 bg-white border border-2 rounded-3 d-flex align-items-start">
                            <div class="text-danger me-3 mt-0.5"><i class="fas fa-map-marker-alt fa-lg"></i></div>
                            <div>
                                <span class="text-dark fw-bold d-block mb-1" style="font-size: 0.95rem;">
                                    @(isDelivery ? Model.DeliveryAddress : Model.PickupAddress)
                                </span>
                                <span class="badge @(isDelivery ? "bg-success" : "bg-primary") bg-opacity-10 @(isDelivery ? "text-success" : "text-primary") small">
                                    Mapped for Active @(isDelivery ? "Drop-off Run" : "Collection Pick")
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <small class="text-muted d-block">Package Service Tier</small>
                            <span class="text-dark fw-bold"><i class="fas fa-shirt text-muted me-1.5"></i>@Model.PackageTier Tier</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Assigned Allocation Time</small>
                            <span class="text-dark fw-bold small"><i class="fas fa-clock text-muted me-1.5"></i>@(Model.DriverAssignedAt?.ToString("g") ?? "N/A")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Interactive Operational Action Update Console -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 mb-4 border border-primary border-opacity-10 h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h6 class="fw-bold mb-0 text-uppercase text-primary tracking-wide" style="font-size: 0.72rem; letter-spacing: 0.5px;">Logistics Action Console</h6>
                </div>
                <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                    
                    @if (Model.Status == Laundry.Models.OrderStatus.PickupAssigned)
                    {
                        <div class="py-2">
                            <div class="mb-3 text-primary"><i class="fas fa-location-arrow fa-3x animate-pulse"></i></div>
                            <h5 class="fw-bold text-dark mb-1">Step 1: Start Transit Run</h5>
                            <p class="text-muted small mb-4">Accept the task assignment and flag your corporate GPS device position as en route to the client's home address.</p>
                            
                            <form asp-action="AdvanceJobStatus" method="post" class="m-0">
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="nextStatus" value="@Laundry.Models.OrderStatus.DriverEnRoute" />
                                <button type="submit" class="btn btn-primary btn-md rounded-pill w-100 fw-bold shadow-sm py-2">
                                    Dispatch Vehicle (Go En Route)
                                </button>
                            </form>
                        </div>
                    }
                    else if (Model.Status == Laundry.Models.OrderStatus.DriverEnRoute)
                    {
                        <div class="py-2">
                            <div class="mb-3 text-warning"><i class="fas fa-box-open fa-3x"></i></div>
                            <h5 class="fw-bold text-dark mb-1">Step 2: Confirm Package Collection</h5>
                            <p class="text-muted small mb-4">Arrived at destination site. Once you collect the laundry secure bags from the customer, mark them loaded into the vehicle storage bay.</p>
                            
                            <form asp-action="AdvanceJobStatus" method="post" class="m-0">
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="nextStatus" value="@Laundry.Models.OrderStatus.PickedUp" />
                                <button type="submit" class="btn btn-warning btn-md text-dark rounded-pill w-100 fw-bold shadow-sm py-2">
                                    Confirm Items Loaded Securely
                                </button>
                            </form>
                        </div>
                    }
                    else if (Model.Status == Laundry.Models.OrderStatus.PickedUp)
                    {
                        <div class="py-2">
                            <div class="mb-3 text-secondary"><i class="fas fa-warehouse fa-3x"></i></div>
                            <h5 class="fw-bold text-dark mb-1">Step 3: Central Facility Delivery</h5>
                            <p class="text-muted small mb-4">Deliver the collected items back to the plant floor for washing. Handing over offloads this package from your active manifest.</p>
                            
                            <form asp-action="AdvanceJobStatus" method="post" class="m-0">
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="nextStatus" value="@Laundry.Models.OrderStatus.AtLaundry" />
                                <button type="submit" class="btn btn-secondary btn-md rounded-pill w-100 fw-bold shadow-sm py-2">
                                    Offload at Plant Facility
                                </button>
                            </form>
                        </div>
                    }
                    else if (Model.Status == Laundry.Models.OrderStatus.OutForDelivery)
                    {
                        <div class="py-2">
                            <div class="mb-3 text-success"><i class="fas fa-truck-moving fa-3x"></i></div>
                            <h5 class="fw-bold text-dark mb-1">Step 4: Confirm Home Return Drop</h5>
                            <p class="text-muted small mb-4">Washing production is complete. Hand over the fresh laundry items to the customer at their destination spot to close the lifecycle ticket.</p>
                            
                            <form asp-action="AdvanceJobStatus" method="post" class="m-0">
                                <input type="hidden" name="orderId" value="@Model.OrderId" />
                                <input type="hidden" name="nextStatus" value="@Laundry.Models.OrderStatus.Delivered" />
                                <button type="submit" class="btn btn-success btn-md rounded-pill w-100 fw-bold shadow-sm py-2">
                                    Mark as Successfully Delivered
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="bg-light rounded-3 border p-4 text-center">
                            <div class="spinner-border spinner-border text-secondary mb-3" role="status"></div>
                            <h6 class="fw-bold text-secondary mb-1">Washing In Progress</h6>
                            <p class="text-muted small mb-0">The client bags have been handed over to the processing team. This page will unlock delivery controls once operators mark processing complete.</p>
                        </div>
                    }

                </div>
            </div>
        }
    </div>
</div>