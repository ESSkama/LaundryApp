@model List<string>
@{
    ViewData["Title"] = "System Logs - Admin";
    var config = ViewBag.Config as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">System Logs (Singleton Pattern)</h1>
        <form method="post" action="/Admin/ClearLogs">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-outline-custom" onclick="return confirm('Clear all logs?')">
                <i class="fas fa-trash"></i> Clear Logs
            </button>
        </form>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="form-container">
                <h5 class="fw-bold mb-3">Order Logger Entries</h5>
                <div class="log-viewer">
                    @foreach (var log in Model)
                    {
                        <div class="log-entry">@log</div>
                    }
                    @if (!Model.Any())
                    {
                        <div class="text-muted text-center py-4">No logs yet.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="form-container">
                <h5 class="fw-bold mb-3">App Configuration</h5>
                @foreach (var setting in config)
                {
                    <div class="config-item">
                        <span class="text-muted">@setting.Key:</span>
                        <span class="fw-bold">@setting.Value</span>
                    </div>
                }
                <hr />
                <small class="text-muted">Singleton ensures single instance across application</small>
            </div>
        </div>
    </div>
</div>

<style>
    .log-viewer {
        background: #1a1a2e;
        color: #00ff9d;
        font-family: monospace;
        font-size: 0.8rem;
        padding: 15px;
        border-radius: 12px;
        max-height: 500px;
        overflow-y: auto;
    }

    .log-entry {
        padding: 5px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .config-item {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #e9ecef;
    }
</style>