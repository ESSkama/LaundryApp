@{
    ViewData["Title"] = "Choose Your Plan - SUDS & SPIN";
    Layout = null;
    var userId = ViewBag.UserId;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --teal: #2A9D8F;
            --teal-dark: #1E6B61;
            --deep-teal: #264653;
            --cream: #F4F1DE;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--cream) 0%, white 100%);
            min-height: 100vh;
            padding: 40px 0;
        }

        .selection-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px;
        }

        .selection-card {
            background: white;
            border-radius: 32px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        }

        .logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .logo i {
            font-size: 3rem;
            color: var(--teal);
        }

        .logo h1 {
            font-size: 1.8rem;
            font-weight: 700;
            margin: 12px 0 4px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .plan-card {
            background: white;
            border-radius: 24px;
            padding: 32px 24px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            height: 100%;
            cursor: pointer;
            border: 2px solid transparent;
        }

        .plan-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        }

        .plan-card.selected {
            border-color: var(--teal);
            background: rgba(42,157,143,0.05);
        }

        .plan-card.popular {
            border: 2px solid var(--teal);
            position: relative;
        }

        .popular-badge {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--teal);
            color: white;
            padding: 4px 16px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .plan-icon {
            width: 70px;
            height: 70px;
            background: rgba(42,157,143,0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .plan-icon i {
            font-size: 2rem;
            color: var(--teal);
        }

        .plan-name {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .plan-price {
            font-size: 2rem;
            font-weight: 800;
            color: var(--teal);
            margin-bottom: 20px;
        }

        .plan-price small {
            font-size: 0.8rem;
            font-weight: 400;
            color: #6c757d;
        }

        .plan-features {
            list-style: none;
            padding: 0;
            margin: 24px 0;
            text-align: left;
        }

        .plan-features li {
            padding: 8px 0;
            color: #4a5568;
        }

        .plan-features i {
            color: var(--teal);
            margin-right: 10px;
            width: 20px;
        }

        .btn-continue {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            border: none;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            color: white;
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-continue:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(42,157,143,0.3);
        }

        .btn-continue:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .alert {
            border-radius: 16px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="selection-container">
            <div class="selection-card">
                <div class="logo">
                    <i class="fas fa-tshirt"></i>
                    <h1>SUDS & SPIN</h1>
                    <p class="text-muted">Choose the perfect subscription plan for you</p>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <form id="subscriptionForm" method="post" action="/Subscription/Select">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@userId" />
                    <input type="hidden" name="selectedTier" id="selectedTier" value="" />

                    <div class="row g-4">
                        <!-- Standard Plan -->
                        <div class="col-md-4">
                            <div class="plan-card" data-tier="standard">
                                <div class="plan-icon">
                                    <i class="fas fa-box"></i>
                                </div>
                                <h3 class="plan-name">Standard</h3>
                                <div class="plan-price">R49 <small>/month</small></div>
                                <ul class="plan-features">
                                    <li><i class="fas fa-check-circle"></i> 2 free deliveries/month</li>
                                    <li><i class="fas fa-check-circle"></i> 5% off all services</li>
                                    <li><i class="fas fa-check-circle"></i> Basic packaging</li>
                                    <li><i class="fas fa-check-circle"></i> Standard delivery (2-3 days)</li>
                                    <li><i class="fas fa-check-circle"></i> Standard detergent</li>
                                    <li><i class="fas fa-check-circle"></i> Email support</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Premium Plan (Popular) -->
                        <div class="col-md-4">
                            <div class="plan-card popular" data-tier="premium">
                                <div class="popular-badge">Most Popular</div>
                                <div class="plan-icon">
                                    <i class="fas fa-crown"></i>
                                </div>
                                <h3 class="plan-name">Premium</h3>
                                <div class="plan-price">R99 <small>/month</small></div>
                                <ul class="plan-features">
                                    <li><i class="fas fa-check-circle"></i> 5 free deliveries/month</li>
                                    <li><i class="fas fa-check-circle"></i> 10% off all services</li>
                                    <li><i class="fas fa-check-circle"></i> Premium eco-friendly packaging</li>
                                    <li><i class="fas fa-check-circle"></i> Express delivery (same-day)</li>
                                    <li><i class="fas fa-check-circle"></i> Premium hypoallergenic detergent</li>
                                    <li><i class="fas fa-check-circle"></i> Free fabric softener</li>
                                    <li><i class="fas fa-check-circle"></i> Priority support</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Business Plan -->
                        <div class="col-md-4">
                            <div class="plan-card" data-tier="business">
                                <div class="plan-icon">
                                    <i class="fas fa-briefcase"></i>
                                </div>
                                <h3 class="plan-name">Business</h3>
                                <div class="plan-price">R199 <small>/month</small></div>
                                <ul class="plan-features">
                                    <li><i class="fas fa-check-circle"></i> 10 free deliveries/month</li>
                                    <li><i class="fas fa-check-circle"></i> 15% off all services</li>
                                    <li><i class="fas fa-check-circle"></i> Corporate branded packaging</li>
                                    <li><i class="fas fa-check-circle"></i> Priority delivery (next-day AM)</li>
                                    <li><i class="fas fa-check-circle"></i> Commercial grade detergent</li>
                                    <li><i class="fas fa-check-circle"></i> Bulk discounts available</li>
                                    <li><i class="fas fa-check-circle"></i> 24/7 dedicated support</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <button type="submit" id="continueBtn" class="btn-continue" disabled>Continue to Login</button>
                    </div>
                </form>

                <hr class="my-4">

                <div class="text-center">
                    <p class="text-muted small">You can change or cancel your subscription at any time from your account dashboard.</p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <script>
        $(document).ready(function() {
            let selectedTier = null;
            
            $('.plan-card').on('click', function() {
                // Remove selected class from all cards
                $('.plan-card').removeClass('selected');
                
                // Add selected class to clicked card
                $(this).addClass('selected');
                
                // Get selected tier
                selectedTier = $(this).data('tier');
                $('#selectedTier').val(selectedTier);
                
                // Enable continue button
                $('#continueBtn').prop('disabled', false);
            });
            
            // Handle form submission
            $('#subscriptionForm').on('submit', function(e) {
                if (!selectedTier) {
                    e.preventDefault();
                    alert('Please select a subscription plan to continue.');
                    return false;
                }
                
                $('#continueBtn').html('<i class="fas fa-spinner fa-spin"></i> Processing...').prop('disabled', true);
            });
        });
    </script>
</body>
</html>