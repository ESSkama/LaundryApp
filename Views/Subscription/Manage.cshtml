@model Laundry.Models.Subscription
@{
    ViewData["Title"] = "My Subscription - SUDS & SPIN";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    var availablePlans = ViewBag.AvailablePlans as List<Laundry.Models.ViewModels.SubscriptionPlan> ?? new List<Laundry.Models.ViewModels.SubscriptionPlan>();
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-lg-5">
                    <div class="text-center mb-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="fas fa-crown fa-3x" style="color: var(--teal);"></i>
                        </div>
                        <h1 class="fw-bold" style="color: var(--deep-navy);">My Subscription</h1>
                        <p class="text-muted">Manage your laundry subscription benefits</p>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (Model == null || !Model.IsActive)
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-gem fa-4x text-muted mb-3"></i>
                            <h4 class="text-muted">No Active Subscription</h4>
                            <p class="text-muted mb-4">Subscribe to a plan to enjoy discounts and free deliveries!</p>
                            <a href="/Subscription/Upgrade" class="btn btn-primary rounded-pill px-4 py-2" style="background: linear-gradient(135deg, var(--teal), var(--teal-dark)); border: none;">
                                <i class="fas fa-crown me-2"></i> View Plans
                            </a>
                        </div>
                    }
                    else
                    {
                        <!-- Current Plan Card -->
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="card text-center border-0 rounded-4 h-100" style="background: linear-gradient(135deg, var(--teal), var(--teal-dark));">
                                    <div class="card-body p-4">
                                        <i class="fas fa-crown fa-3x text-white mb-3"></i>
                                        <h3 class="fw-bold text-white">@Model.Tier</h3>
                                        <div class="display-5 fw-bold text-white">
                                            R@(Model.MonthlyPrice)<small class="fs-6">/month</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="card border-0 bg-light rounded-4 h-100">
                                    <div class="card-body p-4">
                                        <h5 class="fw-bold mb-3" style="color: var(--deep-navy);">Your Benefits</h5>
                                        <div class="row g-3">
                                            <div class="col-sm-6">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-truck fa-lg" style="color: var(--teal);"></i>
                                                    <div>
                                                        <small class="text-muted d-block">Free Deliveries</small>
                                                        <span class="fw-bold">@Model.FreeDeliveriesPerMonth / month</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-percent fa-lg" style="color: var(--teal);"></i>
                                                    <div>
                                                        <small class="text-muted d-block">Discount Rate</small>
                                                        <span class="fw-bold">@Model.DiscountRate.ToString("P0")</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-calendar-alt fa-lg" style="color: var(--teal);"></i>
                                                    <div>
                                                        <small class="text-muted d-block">Start Date</small>
                                                        <span class="fw-bold">@Model.StartDate.ToString("dd MMM yyyy")</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-check-circle fa-lg" style="color: var(--teal);"></i>
                                                    <div>
                                                        <small class="text-muted d-block">Status</small>
                                                        <span class="fw-bold text-success">Active</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex flex-wrap justify-content-center gap-3">
                            <a href="/Subscription/Upgrade" class="btn btn-primary rounded-pill px-4" style="background: linear-gradient(135deg, var(--teal), var(--teal-dark)); border: none;">
                                <i class="fas fa-arrow-up me-2"></i> Upgrade Plan
                            </a>
                            <form method="post" action="/Subscription/Cancel" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger rounded-pill px-4" onclick="return confirm('Are you sure you want to cancel your subscription? You will lose all benefits.')">
                                    <i class="fas fa-ban me-2"></i> Cancel Subscription
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Business Hours Notice -->
    <div class="row mt-4">
        <div class="col-12 text-center">
            <div class="alert alert-warning d-inline-flex align-items-center gap-2">
                <i class="fas fa-clock me-2"></i>
                <small>Customer support available: Monday - Saturday, 8am - 5pm (Closed Sundays)</small>
            </div>
        </div>
    </div>

    <!-- Prorated Upgrade Info -->
    @if (Model != null && Model.IsActive)
    {
        <div class="row mt-4">
            <div class="col-12 text-center">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Upgrade Information:</strong> Upgrading will apply immediately. You'll only pay the prorated difference for the remainder of your billing cycle.
                    <br>
                    <small>Example: If you upgrade halfway through the month, you'll only pay the difference for the remaining days.</small>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .rounded-4 {
        border-radius: 1rem !important;
    }

    .rounded-pill {
        border-radius: 50px !important;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        }
</style>